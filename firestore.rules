rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }
    function ownsPostById(postId) {
      return exists(/databases/$(database)/documents/users/$(request.auth.uid)/ownedPosts/$(postId))
        && get(/databases/$(database)/documents/users/$(request.auth.uid)/ownedPosts/$(postId)).data.authorUid == request.auth.uid;
    }

    match /users/{userId} {
      allow read, create, update, delete: if isSignedIn() && request.auth.uid == userId;
    }

    match /users/{userId}/ownedPosts/{postId} {
      allow read: if isSignedIn();
      allow create, update, delete: if isSignedIn() && request.auth.uid == userId;
    }

    match /posts/{postId} {
      function ownedPostsLink() {
        return get(/databases/$(database)/documents/users/$(request.auth.uid)/ownedPosts/$(postId));
      }
      function ownedPostsLinkAfter() {
        return getAfter(/databases/$(database)/documents/users/$(request.auth.uid)/ownedPosts/$(postId));
      }

      allow read: if true;

      allow create: if isSignedIn()
        && !(request.resource.data.keys().hasAll(["uid"]))
        && request.resource.data.keys().hasAll([
          "authorUid",
          "authorPublicId",
          "claimToken",
          "location",
          "locationDescription",
          "description",
          "motivation",
          "questions",
          "createdAt",
        ])
        && request.resource.data.authorUid == request.auth.uid
        && request.resource.data.claimToken == ownedPostsLinkAfter().data.claimToken
        && ownedPostsLinkAfter().data.authorUid == request.auth.uid;

      allow update, delete: if isSignedIn()
        && resource.data.claimToken == ownedPostsLink().data.claimToken
        && ownedPostsLink().data.authorUid == request.auth.uid;

      match /responses/{responseUserId} {
        allow create: if isSignedIn()
          && request.auth.uid == responseUserId
          && request.resource.data.responderUid == responseUserId
          && request.auth.uid != get(/databases/$(database)/documents/posts/$(postId)).data.authorUid;

        allow update: if isSignedIn()
          && request.auth.uid == responseUserId
          && request.resource.data.responderUid == responseUserId
          && request.auth.uid != get(/databases/$(database)/documents/posts/$(postId)).data.authorUid;

        allow update: if isSignedIn()
          && ownsPostById(postId);

        allow delete: if isSignedIn()
          && ownsPostById(postId);

        allow read: if isSignedIn() && (
          request.auth.uid == resource.data.responderUid ||
          request.auth.uid == responseUserId ||
          ownsPostById(postId)
        );
      }
    }

    match /chats/{chatId} {
      allow create: if isSignedIn()
        && request.resource.data.posterUid == request.auth.uid
        && request.resource.data.participants is list
        && request.resource.data.participants.hasAll([request.auth.uid])
        && request.resource.data.participants.size() == 2;

      allow read, delete: if isSignedIn()
        && (
          (
            resource.data.participants is list
            && resource.data.participants.hasAny([request.auth.uid])
          ) ||
          request.auth.uid == resource.data.posterUid ||
          request.auth.uid == resource.data.responderUid ||
          (
            resource.data.postId is string
            && ownsPostById(resource.data.postId)
          )
        );

      allow update: if isSignedIn() && (
        (
          resource.data.participants is list
          && resource.data.participants.hasAny([request.auth.uid])
        ) ||
        (
          request.resource.data.posterUid == request.auth.uid
          && request.resource.data.participants is list
          && request.resource.data.participants.hasAll([request.auth.uid])
          && request.resource.data.participants.size() == 2
        )
      );

      match /messages/{messageId} {
        allow create: if isSignedIn()
          && (
            get(/databases/$(database)/documents/chats/$(chatId)).data.participants.hasAny([request.auth.uid]) ||
            request.auth.uid == get(/databases/$(database)/documents/chats/$(chatId)).data.posterUid ||
            request.auth.uid == get(/databases/$(database)/documents/chats/$(chatId)).data.responderUid ||
            (
              get(/databases/$(database)/documents/chats/$(chatId)).data.postId is string
              && ownsPostById(get(/databases/$(database)/documents/chats/$(chatId)).data.postId)
            )
          );

        allow read, delete: if isSignedIn()
          && (
            get(/databases/$(database)/documents/chats/$(chatId)).data.participants.hasAny([request.auth.uid]) ||
            request.auth.uid == get(/databases/$(database)/documents/chats/$(chatId)).data.posterUid ||
            request.auth.uid == get(/databases/$(database)/documents/chats/$(chatId)).data.responderUid ||
            (
              get(/databases/$(database)/documents/chats/$(chatId)).data.postId is string
              && ownsPostById(get(/databases/$(database)/documents/chats/$(chatId)).data.postId)
            )
          );
      }
    }
  }
}
